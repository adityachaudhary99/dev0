---
import Base from '../layouts/Base.astro';
---
<Base
  title="dev0 pro — support the free tools"
  description="Everything on dev0 is free. Pro exists so future heavy or team features can fund the free tools. Activate a license key locally — verified offline, no server."
>
  <div class="fade-in max-w-2xl">
    <h1 class="text-3xl sm:text-4xl tracking-tight">dev0 pro</h1>
    <p class="label mt-2">support the free tools</p>

    <p class="mt-8 text-sm text-muted leading-relaxed">
      Everything on dev0 is free right now. Pro exists so future heavy or team
      features can fund the free tools — it doesn't lock anything you use today.
    </p>
    <p class="mt-3 text-sm text-muted leading-relaxed">
      License keys are signed and verified entirely in your browser. No license
      server, no phone-home. Activate one below and it lives in this browser only.
    </p>

    <!-- Activation panel -->
    <div class="mt-10 border border-rule bg-raised p-5">
      <p class="label mb-3">license</p>

      <!-- status area -->
      <div id="license-status" class="text-sm leading-relaxed"></div>

      <!-- activation form (hidden when pro is active) -->
      <div id="license-form" class="mt-4">
        <label for="license-input" class="label block mb-2">paste license key</label>
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            id="license-input"
            type="text"
            spellcheck="false"
            autocomplete="off"
            placeholder="0LK1.…"
            class="flex-1 min-w-0 bg-bg border border-rule px-3 py-2 text-sm text-ink placeholder:text-muted focus:border-rule-strong"
          />
          <button
            id="activate-btn"
            type="button"
            class="border border-rule-strong px-4 py-2 text-sm text-ink hover:bg-accent hover:text-accent-ink hover:border-accent transition-colors"
          >Activate</button>
        </div>
        <p id="license-error" class="label mt-3 text-err" hidden></p>
      </div>
    </div>

    <p class="mt-6 text-sm text-muted leading-relaxed">
      Don't have a key yet? There's nothing to buy today — this page is plumbing
      for the future. When pro features ship, they'll be listed here.
    </p>
  </div>

  <script>
    import { activateLicense, getEntitlements, clearLicense } from '../lib/entitlements';

    const statusEl = document.getElementById('license-status')!;
    const formEl = document.getElementById('license-form')!;
    const input = document.getElementById('license-input') as HTMLInputElement;
    const activateBtn = document.getElementById('activate-btn')!;
    const errorEl = document.getElementById('license-error')!;

    async function render() {
      const ent = await getEntitlements();
      if (ent.plan === 'pro') {
        formEl.hidden = true;
        statusEl.replaceChildren();
        const dot = document.createElement('span');
        dot.className = 'text-accent';
        dot.textContent = '●';
        const email = document.createElement('span');
        email.className = 'text-ink';
        email.textContent = ent.email ?? '';
        statusEl.append(dot, ' Pro active · ', email);
        const remove = document.createElement('button');
        remove.type = 'button';
        remove.textContent = 'Remove license';
        remove.className =
          'label mt-4 block hover:text-ink underline underline-offset-4';
        remove.addEventListener('click', () => {
          clearLicense();
          location.reload();
        });
        statusEl.appendChild(remove);
      } else {
        formEl.hidden = false;
        statusEl.innerHTML =
          '<span class="text-muted">Free tier — every tool unlocked. ' +
          'No license active.</span>';
      }
    }

    activateBtn.addEventListener('click', async () => {
      errorEl.hidden = true;
      const ok = await activateLicense(input.value);
      if (ok) {
        input.value = '';
        await render();
      } else {
        errorEl.hidden = false;
        errorEl.textContent = "That license key isn't valid.";
      }
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') activateBtn.dispatchEvent(new Event('click'));
    });

    render();
  </script>
</Base>
