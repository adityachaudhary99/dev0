---
import Base from '../layouts/Base.astro';

const tools = [
  { href: '/jwt', name: 'JWT Decoder & Verifier', desc: 'Decode and verify JWTs (HS256/RS256/ES256) in the browser.' },
  { href: '/regex', name: 'Regex Tester', desc: 'Live match highlighting, capture groups and explanations.' },
  { href: '/cron', name: 'Cron Expression Parser', desc: 'Next 10 runs in your timezone, plus plain English.' },
  { href: '/base64', name: 'Base64 / URL / Hex', desc: 'Encode and decode with auto-detect and byte counts.' },
  { href: '/epoch', name: 'Epoch / Unix Time', desc: 'Convert between Unix timestamps and human dates.' },
  { href: '/json-to-types', name: 'JSON to Types', desc: 'Generate TypeScript types and more from a JSON sample.' },
  { href: '/jq', name: 'jq Playground', desc: 'Run jq filters over JSON, entirely client-side.' },
  { href: '/erd', name: 'ERD from SQL', desc: 'Turn CREATE TABLE statements into an entity diagram.' },
  { href: '/uuid', name: 'UUID Generator', desc: 'Generate and inspect UUIDs (v4, v7 and friends).' },
  { href: '/cert', name: 'Certificate Inspector', desc: 'Decode and inspect X.509 / PEM certificates.' },
];
---
<Base
  title="dev0 — browser dev tools, nothing leaves this page"
  description="A directory of fast, client-side developer tools — JWT, regex, cron, base64 and more. Everything runs in your browser; nothing is ever uploaded."
>
  <div class="fade-in">
    <section class="max-w-2xl">
      <h1 class="display text-4xl sm:text-6xl tracking-tight leading-[1.05]">
        Browser dev tools.<br />
        <span class="text-accent">Nothing leaves this page.</span>
      </h1>
      <p class="label mt-5">100% client-side · 0 trackers · 0 cookies · verify in DevTools → Network</p>
    </section>

    <section class="mt-14 corner-marks border border-rule bg-raised">
      {tools.map((t, i) => (
        <a
          href={t.href}
          class={`group flex items-baseline gap-4 sm:gap-6 px-5 py-4 hover:bg-bg transition-colors ${i === 0 ? '' : 'border-t border-rule'}`}
        >
          <span class="label shrink-0 w-6">{String(i + 1).padStart(2, '0')}</span>
          <span class="shrink-0 w-48 sm:w-56 text-ink group-hover:text-accent transition-colors">{t.name}</span>
          <span class="text-sm text-muted hidden sm:block">{t.desc}</span>
        </a>
      ))}
      <span class="cm"></span>
    </section>
  </div>

  <script is:inline>
    const m = location.hash.match(/^#\/(jwt|regex|cron|b64)$/);
    if (m) location.replace('/' + (m[1] === 'b64' ? 'base64' : m[1]));
  </script>
</Base>
